node_modules/

# build output
dist/

# secrets & local config
.env
.env.*
!.env.example
# Never commit real config/apps files at repo root — only the example
# templates ship. Real credentials live in $HOME/.adaria (prod) or
# $HOME/.adaria-dev (dev profile); see docs/SETUP.md.
/config.yaml
/apps.yaml
!/apps.example.yaml

